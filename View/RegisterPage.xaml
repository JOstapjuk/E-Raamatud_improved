<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:E_Raamatud.ViewModel"
             x:Class="E_Raamatud.RegisterPage"
             BackgroundColor="#F5F7F5"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <viewModel:UserViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="280, *">

        <!-- Top hero area -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,40,40"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="40,60,40,40">
                <VerticalStackLayout VerticalOptions="End" Spacing="6">
                    <Label Text="E-RAAMATUD"
                           FontSize="11"
                           TextColor="#a8d4c8"
                           CharacterSpacing="4" />
                    <Label Text="Loo konto"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Alusta oma lugemisteekonda"
                           FontSize="14"
                           TextColor="#c8e0dc"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Form area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="32,36,32,32" Spacing="0">

                <Label Text="UUS KASUTAJA"
                       FontSize="11"
                       TextColor="#98a8a0"
                       CharacterSpacing="3"
                       Margin="4,0,0,16" />

                <!-- Username -->
                <VerticalStackLayout Spacing="0" Margin="0,0,0,18">
                    <Label Text="Kasutajanimi"
                           FontSize="13"
                           TextColor="#3a5c52"
                           FontAttributes="Bold"
                           Margin="4,0,0,8" />
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="#e0e6e2"
                            StrokeThickness="1.5"
                            BackgroundColor="White"
                            Padding="16,2">
                        <Entry Placeholder="Vali kasutajanimi"
                               Text="{Binding Username}"
                               FontSize="15"
                               TextColor="#1f2e28"
                               PlaceholderColor="#a8b5ad"
                               BackgroundColor="Transparent"
                               HeightRequest="50" />
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout Spacing="0" Margin="0,0,0,18">
                    <Label Text="Parool"
                           FontSize="13"
                           TextColor="#3a5c52"
                           FontAttributes="Bold"
                           Margin="4,0,0,8" />
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="#e0e6e2"
                            StrokeThickness="1.5"
                            BackgroundColor="White"
                            Padding="16,2">
                        <Entry Placeholder="Loo tugev parool"
                               IsPassword="True"
                               Text="{Binding Password}"
                               FontSize="15"
                               TextColor="#1f2e28"
                               PlaceholderColor="#a8b5ad"
                               BackgroundColor="Transparent"
                               HeightRequest="50" />
                    </Border>
                </VerticalStackLayout>

                <!-- Role picker -->
                <VerticalStackLayout Spacing="0" Margin="0,0,0,8">
                    <Label Text="Roll"
                           FontSize="13"
                           TextColor="#3a5c52"
                           FontAttributes="Bold"
                           Margin="4,0,0,8" />
                    <Border StrokeShape="RoundRectangle 12"
                            Stroke="#e0e6e2"
                            StrokeThickness="1.5"
                            BackgroundColor="White"
                            Padding="16,2">
                        <Picker Title="Vali roll"
                                TitleColor="#a8b5ad"
                                ItemsSource="{Binding Roles}"
                                SelectedItem="{Binding SelectedRole}"
                                FontSize="15"
                                TextColor="#1f2e28"
                                BackgroundColor="Transparent"
                                HeightRequest="50" />
                    </Border>
                </VerticalStackLayout>

                <Label Text="{Binding LoginStatus}"
                       TextColor="#c94545"
                       FontSize="13"
                       HorizontalOptions="Center"
                       Margin="0,8,0,28" />

                <!-- Primary action -->
                <Button Text="Registreeru"
                        Command="{Binding RegisterCommand}"
                        BackgroundColor="#2d6e68"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="54"
                        Margin="0,0,0,16" />

                <!-- Back button -->
                <Button Text="Tagasi"
                        Clicked="GoBack_Clicked"
                        BackgroundColor="Transparent"
                        BorderColor="#cad4ce"
                        BorderWidth="1.5"
                        TextColor="#3a5c52"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="54"
                        Margin="0,0,0,20" />

                <!-- Login link -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="On juba konto?"
                           FontSize="14"
                           TextColor="#6a7d75"
                           VerticalOptions="Center" />
                    <Label Text="Logi sisse"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#2d6e68"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="GoBack_Clicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>