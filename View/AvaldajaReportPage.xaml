<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.View.AvaldajaReportPage"
             x:Name="AvaldajaReportPageRef"
             BackgroundColor="#FAF8F3"
             Shell.NavBarIsVisible="False"
             Title="Muugiaruanne">

    <Grid RowDefinitions="Auto, *">

        <!-- ============== ШАПКА ============== -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,50,24,28"
                  ColumnDefinitions="Auto, *, Auto">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#1f4f4a"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path Stroke="White" StrokeThickness="2"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="16" WidthRequest="16"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 14,6 L 8,12 L 14,18" />
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Label Text="Muugiaruanne"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label x:Name="ReportSubtitle"
                           Text="Sinu raamatute statistika"
                           FontSize="12"
                           TextColor="#c8e0dc"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <BoxView Grid.Column="2"
                         WidthRequest="40"
                         HeightRequest="40"
                         Color="Transparent" />
            </Grid>
        </Border>

        <!-- ============== КОНТЕНТ ============== -->
        <Grid Grid.Row="1">

            <!-- Пустое состояние -->
            <VerticalStackLayout x:Name="EmptyView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="14"
                                 Padding="40">

                <Border StrokeShape="RoundRectangle 50"
                        Stroke="Transparent"
                        BackgroundColor="#fff5e8"
                        WidthRequest="120"
                        HeightRequest="120"
                        Padding="0">
                    <Path Stroke="#d97a4a" StrokeThickness="2.5"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="56" WidthRequest="56"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 4,20 L 4,4 M 4,20 L 20,20 M 8,16 L 8,12 M 12,16 L 12,8 M 16,16 L 16,10 M 20,16 L 20,6" />
                </Border>

                <Label Text="Pole veel muuke"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#1f2e28"
                       HorizontalOptions="Center" />

                <Label Text="Kui sinu raamatuid ostetakse, ilmuvad need siia"
                       FontSize="13"
                       TextColor="#5f5e5a"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Список с отчётом -->
            <ScrollView x:Name="ReportScroll" IsVisible="False">
                <VerticalStackLayout Padding="24,24,24,32" Spacing="16">

                    <!-- Сводные карточки -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="#e8f0ed"
                                Padding="18,14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="MUUDUD KOKKU"
                                       FontSize="10"
                                       TextColor="#0f6e56"
                                       CharacterSpacing="2"
                                       FontAttributes="Bold" />
                                <Label x:Name="TotalSoldLabel"
                                       Text="0"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#1f2e28" />
                                <Label Text="raamatut"
                                       FontSize="11"
                                       TextColor="#5f5e5a" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 14"
                                Stroke="Transparent"
                                BackgroundColor="#fff5e8"
                                Padding="18,14">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="TULU KOKKU"
                                       FontSize="10"
                                       TextColor="#993c1d"
                                       CharacterSpacing="2"
                                       FontAttributes="Bold" />
                                <Label x:Name="TotalRevenueLabel"
                                       Text="0,00"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#1f2e28" />
                                <Label Text="kogu aja jooksul"
                                       FontSize="11"
                                       TextColor="#5f5e5a" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Заголовок секции -->
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center" Margin="0,8,0,0">
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="#f0eaf7"
                                WidthRequest="32"
                                HeightRequest="32"
                                Padding="0">
                            <Path Stroke="#534ab7" StrokeThickness="1.7"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="16" WidthRequest="16"
                                  HorizontalOptions="Center" VerticalOptions="Center"
                                  Data="M 4,5 L 4,19 C 4,19 7,18 12,18 C 17,18 20,19 20,19 L 20,5 C 20,5 17,4 12,4 C 7,4 4,5 4,5 Z M 12,4 L 12,18" />
                        </Border>
                        <Label Text="Raamatud"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1f2e28"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Список книг с продажами -->
                    <VerticalStackLayout x:Name="ReportListLayout"
                                         BindableLayout.ItemsSource="{Binding .}"
                                         Spacing="10">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 14"
                                        Stroke="#e5ebe7"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="18">
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.05" />
                                    </Border.Shadow>

                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">

                                        <!-- Иконка ранга -->
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 22"
                                                Stroke="Transparent"
                                                BackgroundColor="#2d6e68"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                Padding="0"
                                                VerticalOptions="Center">
                                            <Path Stroke="White" StrokeThickness="1.7"
                                                  Fill="Transparent" Aspect="Uniform"
                                                  HeightRequest="20" WidthRequest="20"
                                                  HorizontalOptions="Center" VerticalOptions="Center"
                                                  Data="M 4,5 L 4,19 C 4,19 7,18 12,18 C 17,18 20,19 20,19 L 20,5 C 20,5 17,4 12,4 C 7,4 4,5 4,5 Z M 12,4 L 12,18" />
                                        </Border>

                                        <!-- Информация -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="6"
                                                             VerticalOptions="Center">

                                            <Label Text="{Binding Pealkiri}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#1f2e28"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />

                                            <HorizontalStackLayout Spacing="6">

                                                <Border StrokeShape="RoundRectangle 6"
                                                        Stroke="Transparent"
                                                        BackgroundColor="#e8f0ed"
                                                        Padding="8,3">
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Path Stroke="#0f6e56" StrokeThickness="1.7"
                                                              Fill="Transparent" Aspect="Uniform"
                                                              HeightRequest="10" WidthRequest="10"
                                                              VerticalOptions="Center"
                                                              Data="M 4,7 L 20,7 L 19,19 L 5,19 Z" />
                                                        <Label Text="{Binding KokkuMuudud, StringFormat='{0} tk'}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="#0f6e56"
                                                               VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Сумма выручки -->
                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="2"
                                                             VerticalOptions="Center"
                                                             HorizontalOptions="End">
                                            <Label Text="TULU"
                                                   FontSize="9"
                                                   TextColor="#98a8a0"
                                                   CharacterSpacing="1.5"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End" />
                                            <Label Text="{Binding KokkuTulu, StringFormat='EUR {0:F2}'}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#2d6e68"
                                                   HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Состояние ошибки -->
            <VerticalStackLayout x:Name="ErrorView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 Padding="40">
                <Label Text="Viga"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#d97a4a"
                       HorizontalOptions="Center" />
                <Label x:Name="ErrorMessage"
                       Text="Andmete laadimisel tekkis viga"
                       FontSize="13"
                       TextColor="#5f5e5a"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>