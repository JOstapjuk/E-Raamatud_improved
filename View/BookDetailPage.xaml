<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:E_Raamatud.Resources.Localization"
             x:Class="E_Raamatud.BookDetailPage"
             x:Name="BookDetailPageRef"
             BackgroundColor="#FAF8F3"
             SizeChanged="OnPageSizeChanged"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,50,24,28" ColumnDefinitions="Auto, *, Auto">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#1f4f4a"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path Stroke="White" StrokeThickness="2"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="16" WidthRequest="16"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 14,6 L 8,12 L 14,18" />
                </Border>

                <Label Grid.Column="1"
                       Text="Raamatu detailid"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"
                       HorizontalOptions="Center" />

                <Label Grid.Column="2" WidthRequest="40" HeightRequest="40" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <Grid x:Name="ContentRoot"
                  Padding="32,28,32,32"
                  RowSpacing="28"
                  ColumnSpacing="36">

                <Border x:Name="CoverBorder"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        WidthRequest="320"
                        HeightRequest="460"
                        Padding="0"
                        VerticalOptions="Start"
                        HorizontalOptions="Start">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,8" Radius="20" Opacity="0.18" />
                    </Border.Shadow>
                    <Image Source="{Binding Pilt}"
                           Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout x:Name="InfoPanel"
                                     Spacing="14"
                                     VerticalOptions="Start">

                    <Border StrokeShape="RoundRectangle 6"
                            Stroke="Transparent"
                            BackgroundColor="#e8f0ed"
                            Padding="12,5"
                            HorizontalOptions="Start">
                        <Label Text="{Binding Zanr_Nimi}"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#0f6e56"
                               CharacterSpacing="1.5" />
                    </Border>

                    <!-- Title -->
                    <Label x:Name="TitleLabel"
                           Text="{Binding Pealkiri}"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#1f2e28"
                           LineHeight="1.15" />

                    <!-- READ / LISTEN BUTTONS -->
                    <HorizontalStackLayout x:Name="ActionButtons" Spacing="12">

                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="Transparent"
                                BackgroundColor="#2d6e68"
                                HeightRequest="52"
                                MinimumWidthRequest="160"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReadTapped" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                <Path Stroke="White" StrokeThickness="1.8" Fill="Transparent"
                                      Aspect="Uniform" HeightRequest="16" WidthRequest="16"
                                      VerticalOptions="Center"
                                      Data="M 4,4 L 4,20 L 20,12 Z" />
                                <Label Text="{x:Static loc:AppResources.ReadButton}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <Border x:Name="ListenButton"
                                StrokeShape="RoundRectangle 12"
                                Stroke="#d5dfd8"
                                StrokeThickness="1"
                                BackgroundColor="White"
                                HeightRequest="52"
                                MinimumWidthRequest="160"
                                Padding="0"
                                IsVisible="False">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnListenTapped" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                                <Path Stroke="#2d6e68" StrokeThickness="1.8" Fill="Transparent"
                                      Aspect="Uniform" HeightRequest="16" WidthRequest="16"
                                      VerticalOptions="Center"
                                      Data="M 12,3 C 7,3 4,7 4,12 L 4,15 L 4,17 L 7,17 L 7,12 M 12,3 C 17,3 20,7 20,12 L 20,15 L 20,17 L 17,17 L 17,12" />
                                <Label Text="{x:Static loc:AppResources.ListenButton}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#2d6e68" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="#e5ebe7"
                             HorizontalOptions="Fill" Margin="0,8,0,4" />

                    <!-- Description -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="{x:Static loc:AppResources.DescriptionFieldLabel}"
                               FontSize="10"
                               TextColor="#98a8a0"
                               CharacterSpacing="2"
                               FontAttributes="Bold" />
                        <Label Text="{Binding Kirjeldus}"
                               FontSize="14"
                               TextColor="#3a5c52"
                               LineHeight="1.55" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
