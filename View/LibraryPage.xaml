<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.View.LibraryPage"
             Title="Minu Raamatukogu">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#549082" Offset="0.0" />
            <GradientStop Color="#406780" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <StackLayout Padding="10" Spacing="20">

        <Label Text="Minu Raamatukogu"
               FontSize="30"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center" />

        <CollectionView x:Name="LibraryCollectionView"
                ItemsSource="{Binding LibraryBooks}">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame HasShadow="True"
                       CornerRadius="8"
                       Padding="0"
                       BackgroundColor="White"
                       Margin="5">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnItemTapped" NumberOfTapsRequired="1" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Padding="8" Spacing="5">
                            <Image Source="{Binding Pilt}"
                       HeightRequest="150"
                       Aspect="AspectFill" />
                            <Label Text="{Binding Pealkiri}"
                       TextColor="#1a1a1a"
                       FontAttributes="Bold"
                       FontSize="13"
                       LineBreakMode="TailTruncation" />
                            <ProgressBar Progress="{Binding ProgressValue}"
                             ProgressColor="#549082" />
                            <Label Text="{Binding ProgressText}"
                       TextColor="#888888"
                       FontSize="11"
                       HorizontalOptions="End" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </StackLayout>

</ContentPage>