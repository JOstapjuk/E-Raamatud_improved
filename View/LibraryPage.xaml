<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.View.LibraryPage"
             x:Name="LibraryPageRef"
             BackgroundColor="#FAF8F3"
             Shell.NavBarIsVisible="False"
             Title="Minu raamatukogu">

    <Grid RowDefinitions="Auto, *">

        <!-- ============== ШАПКА ============== -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <VerticalStackLayout Padding="24,50,24,28" Spacing="16">

                <Grid ColumnDefinitions="Auto, *, Auto">

                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            BackgroundColor="#1f4f4a"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="‹"
                           TextColor="White"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center">
                        <Label Text="Minu raamatukogu"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <Label x:Name="BooksCountLabel"
                               Text="Sinu ostetud raamatud"
                               FontSize="12"
                               TextColor="#c8e0dc"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                       WidthRequest="40"
                       HeightRequest="40" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ============== КОНТЕНТ ============== -->
        <Grid Grid.Row="1">

            <!-- Пустое состояние -->
            <VerticalStackLayout x:Name="EmptyView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="14"
                                 Padding="40">

                <Border StrokeShape="RoundRectangle 50"
                        Stroke="Transparent"
                        BackgroundColor="#e8f0ed"
                        WidthRequest="120"
                        HeightRequest="120"
                        Padding="0">
                    <Label Text="📚"
                       FontSize="48"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
                </Border>

                <Label Text="Sa ei loe hetkel ühtegi raamatut"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#1f2e28"
                       HorizontalOptions="Center" />

                <Label Text="Ava raamat ja alusta lugemist"
                       FontSize="13"
                       TextColor="#5f5e5a"
                       HorizontalOptions="Center" />

                    <Button Text="Mine raamatulettele"
                        WidthRequest="220"
                        Clicked="OnBackTapped"
                        BackgroundColor="#2d6e68"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="10"
                        HeightRequest="46"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- Список книг -->
            <ScrollView x:Name="BooksScroll">
                <VerticalStackLayout Padding="24,24,24,32" Spacing="14">

                    <CollectionView x:Name="BooksList">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="14" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 14"
                                    Stroke="#e5ebe7"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    Padding="16"
                                    Margin="0,0,0,0">
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.06" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBookTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">

                                        <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            Padding="0"
                                            WidthRequest="80"
                                            HeightRequest="120">
                                            <Border.Shadow>
                                                <Shadow Brush="#000000" Offset="0,3" Radius="8" Opacity="0.18" />
                                            </Border.Shadow>
                                            <Image Source="{Binding PiltOrPlaceholder}" Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="4"
                                             VerticalOptions="Center">
                                            <Border StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                BackgroundColor="#e8f0ed"
                                                Padding="8,3"
                                                HorizontalOptions="Start">
                                                <Label Text="LOEB"
                                                   FontSize="9"
                                                   FontAttributes="Bold"
                                                   TextColor="#0f6e56"
                                                   CharacterSpacing="1.5" />
                                            </Border>
                                            <Label Text="{Binding Pealkiri}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1f2e28"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                            <Label Text="{Binding Kirjeldus}"
                                               FontSize="11"
                                               TextColor="#98a8a0"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                            <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                                                <ProgressBar Progress="{Binding ProgressValue}"
                                                     ProgressColor="#2d6e68"
                                                     BackgroundColor="#e8f0ed"
                                                     HeightRequest="4"
                                                     WidthRequest="100" />
                                                <Label Text="{Binding ProgressText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#2d6e68"
                                                   VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2"
                                            StrokeShape="RoundRectangle 20"
                                            Stroke="Transparent"
                                            BackgroundColor="#f0f4f2"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnBookMenuTapped" />
                                            </Border.GestureRecognizers>
                                            <Label Text="···"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#2d6e68"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                        </Border>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>