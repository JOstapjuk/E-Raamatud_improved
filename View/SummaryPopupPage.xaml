<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.View.SummaryPopupPage"
             BackgroundColor="#80000000"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Dim background tap to close -->
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Card -->
        <Border HorizontalOptions="Fill"
                VerticalOptions="Fill"
                StrokeShape="RoundRectangle 16"
                Stroke="Transparent"
                BackgroundColor="#1e1e1e"
                Padding="0"
                Margin="16">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.4" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto, *, Auto">

                <!-- Header -->
                <Grid Grid.Row="0"
                      Padding="24,20,16,16"
                      ColumnDefinitions="*, Auto">
                    <Label x:Name="TitleLabel"
                           Grid.Column="0"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            BackgroundColor="#333333"
                            WidthRequest="36"
                            HeightRequest="36"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="✕"
                               TextColor="#aaaaaa"
                               FontSize="14"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Divider -->
                <BoxView Grid.Row="0"
                         VerticalOptions="End"
                         HeightRequest="1"
                         Color="#333333" />

                <!-- WebView renders markdown as HTML -->
                <WebView x:Name="SummaryWebView"
                         Grid.Row="1"
                         MinimumHeightRequest="300" />

                <!-- Footer disclaimer -->
                <Border Grid.Row="2"
                        Padding="20,14"
                        StrokeShape="RoundRectangle 0,0,16,16"
                        Stroke="Transparent"
                        BackgroundColor="#252525">
                    <Label Text="See kokkuvõte on loodud tehisintellekti poolt ja võib sisaldada ebatäpsusi."
                           FontSize="11"
                           TextColor="#888888"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </Border>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
