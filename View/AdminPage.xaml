<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:E_Raamatud.ViewModel"
             x:Class="E_Raamatud.View.AdminPage"
             x:Name="AdminPageRef"
             BackgroundColor="#FAF8F3"
             Shell.NavBarIsVisible="False"
             Title="Admin">

    <Grid RowDefinitions="Auto, *">

        <!-- ============== ШАПКА ============== -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <VerticalStackLayout Padding="24,50,24,28" Spacing="16">

                <Grid ColumnDefinitions="Auto, *, Auto">

                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 20"
                            Stroke="Transparent"
                            BackgroundColor="#1f4f4a"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            VerticalOptions="Center">
                        <Path Stroke="White" StrokeThickness="2"
                              Fill="Transparent" Aspect="Uniform"
                              HeightRequest="18" WidthRequest="18"
                              HorizontalOptions="Center" VerticalOptions="Center"
                              Data="M 12,2 L 4,6 L 4,12 C 4,16 7,20 12,21 C 17,20 20,16 20,12 L 20,6 Z" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center">
                        <Label Text="Admin paneel"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <Label Text="Susteemi haldamine"
                               FontSize="12"
                               TextColor="#c8e0dc"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                       WidthRequest="40"
                       HeightRequest="40" />
                </Grid>

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            BackgroundColor="#c84545"
                            HeightRequest="46"
                            Padding="16,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Path Stroke="White" StrokeThickness="1.8"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="13" WidthRequest="13"
                                  VerticalOptions="Center"
                                  Data="M 14,4 L 18,4 L 18,20 L 14,20 M 4,12 L 14,12 M 10,8 L 14,12 L 10,16" />
                            <Label Text="Logi valja"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ============== КОНТЕНТ ============== -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,24,24,32" Spacing="22">

                <!-- ===== KASUTAJAD ===== -->
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="#e8f0ed"
                                WidthRequest="32"
                                HeightRequest="32"
                                Padding="0">
                            <Path Stroke="#0f6e56" StrokeThickness="1.7"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="16" WidthRequest="16"
                                  HorizontalOptions="Center" VerticalOptions="Center"
                                  Data="M 12,12 C 14.2,12 16,10.2 16,8 C 16,5.8 14.2,4 12,4 C 9.8,4 8,5.8 8,8 C 8,10.2 9.8,12 12,12 Z M 4,20 C 4,17.3 9.3,16 12,16 C 14.7,16 20,17.3 20,20" />
                        </Border>
                        <Label Text="Kasutajad"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1f2e28"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Users}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="#e5ebe7"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 18"
                                                Stroke="Transparent"
                                                BackgroundColor="#e8f0ed"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                Padding="0">
                                            <Path Stroke="#0f6e56" StrokeThickness="1.7"
                                                  Fill="Transparent" Aspect="Uniform"
                                                  HeightRequest="14" WidthRequest="14"
                                                  HorizontalOptions="Center" VerticalOptions="Center"
                                                  Data="M 12,12 C 14.2,12 16,10.2 16,8 C 16,5.8 14.2,4 12,4 C 9.8,4 8,5.8 8,8 C 8,10.2 9.8,12 12,12 Z M 4,20 C 4,17.3 9.3,16 12,16 C 14.7,16 20,17.3 20,20" />
                                        </Border>

                                        <Label Grid.Column="1"
                                               Text="{Binding Username}"
                                               VerticalOptions="Center"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1f2e28" />

                                        <Border Grid.Column="2"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                BackgroundColor="#fdecec"
                                                Padding="14,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteUserTapped"
                                                                      CommandParameter="{Binding Id}" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6">
                                                <Path Stroke="#d63030" StrokeThickness="1.7"
                                                      Fill="Transparent" Aspect="Uniform"
                                                      HeightRequest="12" WidthRequest="12"
                                                      VerticalOptions="Center"
                                                      Data="M 5,7 L 19,7 M 8,7 L 8,4 L 16,4 L 16,7 M 6,7 L 7,20 L 17,20 L 18,7 M 10,11 L 10,17 M 14,11 L 14,17" />
                                                <Label Text="Kustuta"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#d63030"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ===== ZANRID ===== -->
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="#fff5e8"
                                WidthRequest="32"
                                HeightRequest="32"
                                Padding="0">
                            <Path Stroke="#993c1d" StrokeThickness="1.7"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="16" WidthRequest="16"
                                  HorizontalOptions="Center" VerticalOptions="Center"
                                  Data="M 4,4 L 12,4 L 20,12 L 12,20 L 4,12 Z M 8,8 C 8.5,8 9,8.5 9,9 C 9,9.5 8.5,10 8,10 C 7.5,10 7,9.5 7,9 C 7,8.5 7.5,8 8,8 Z" />
                        </Border>
                        <Label Text="Zanrid"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1f2e28"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Genres}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="#e5ebe7"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">

                                        <Label Grid.Column="0"
                                               Text="{Binding Nimetus}"
                                               VerticalOptions="Center"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1f2e28" />

                                        <Border Grid.Column="1"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                BackgroundColor="#fdecec"
                                                Padding="14,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteGenreTapped"
                                                                      CommandParameter="{Binding Zanr_ID}" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6">
                                                <Path Stroke="#d63030" StrokeThickness="1.7"
                                                      Fill="Transparent" Aspect="Uniform"
                                                      HeightRequest="12" WidthRequest="12"
                                                      VerticalOptions="Center"
                                                      Data="M 5,7 L 19,7 M 8,7 L 8,4 L 16,4 L 16,7 M 6,7 L 7,20 L 17,20 L 18,7 M 10,11 L 10,17 M 14,11 L 14,17" />
                                                <Label Text="Kustuta"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#d63030"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ===== RAAMATUD ===== -->
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="Transparent"
                                BackgroundColor="#f0eaf7"
                                WidthRequest="32"
                                HeightRequest="32"
                                Padding="0">
                            <Path Stroke="#534ab7" StrokeThickness="1.7"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="16" WidthRequest="16"
                                  HorizontalOptions="Center" VerticalOptions="Center"
                                  Data="M 4,5 L 4,19 C 4,19 7,18 12,18 C 17,18 20,19 20,19 L 20,5 C 20,5 17,4 12,4 C 7,4 4,5 4,5 Z M 12,4 L 12,18" />
                        </Border>
                        <Label Text="Raamatud"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1f2e28"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Books}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="#e5ebe7"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">

                                        <Label Grid.Column="0"
                                               Text="{Binding Pealkiri}"
                                               VerticalOptions="Center"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1f2e28"
                                               LineBreakMode="TailTruncation" />

                                        <Border Grid.Column="1"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                BackgroundColor="#fdecec"
                                                Padding="14,8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteBookTapped"
                                                                      CommandParameter="{Binding Raamat_ID}" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6">
                                                <Path Stroke="#d63030" StrokeThickness="1.7"
                                                      Fill="Transparent" Aspect="Uniform"
                                                      HeightRequest="12" WidthRequest="12"
                                                      VerticalOptions="Center"
                                                      Data="M 5,7 L 19,7 M 8,7 L 8,4 L 16,4 L 16,7 M 6,7 L 7,20 L 17,20 L 18,7 M 10,11 L 10,17 M 14,11 L 14,17" />
                                                <Label Text="Kustuta"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="#d63030"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>