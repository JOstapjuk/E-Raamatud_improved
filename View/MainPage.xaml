<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:E_Raamatud.ViewModel"
             x:Class="E_Raamatud.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAF8F3"
             SizeChanged="OnPageSizeChanged">

    <ContentPage.Resources>
        <Style x:Key="IconCircleStyle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 22" />
            <Setter Property="Stroke" Value="Transparent" />
            <Setter Property="BackgroundColor" Value="#1f4f4a" />
            <Setter Property="WidthRequest" Value="44" />
            <Setter Property="HeightRequest" Value="44" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══════ HEADER ══════ -->
            <Border StrokeShape="RoundRectangle 0,0,32,32"
                    Stroke="Transparent"
                    Padding="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2d6e68" Offset="0.0" />
                        <GradientStop Color="#3a7d82" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Padding="32,50,32,90" Spacing="22">

                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <Label x:Name="HeaderTitle"
                                   Text="Tere tulemast"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                            <Label x:Name="HeaderSubtitle"
                                   Text="Avasta uusi raamatuid täna"
                                   FontSize="13"
                                   TextColor="#c8e0dc" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Border Style="{StaticResource IconCircleStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUserTapped" />
                                </Border.GestureRecognizers>
                                <Path Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                      Aspect="Uniform" HeightRequest="18" WidthRequest="18"
                                      HorizontalOptions="Center" VerticalOptions="Center"
                                      Data="M 12,12 C 14.2,12 16,10.2 16,8 C 16,5.8 14.2,4 12,4 C 9.8,4 8,5.8 8,8 C 8,10.2 9.8,12 12,12 Z M 12,14 C 9.3,14 4,15.3 4,18 L 4,20 L 20,20 L 20,18 C 20,15.3 14.7,14 12,14 Z" />
                            </Border>

                            <Border Style="{StaticResource IconCircleStyle}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLibraryTapped" />
                                </Border.GestureRecognizers>
                                <Path Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                      Aspect="Uniform" HeightRequest="18" WidthRequest="18"
                                      HorizontalOptions="Center" VerticalOptions="Center"
                                      Data="M 12,21 C 12,21 4,16 4,10 C 4,7.8 5.8,6 8,6 C 9.5,6 10.8,6.8 12,8 C 13.2,6.8 14.5,6 16,6 C 18.2,6 20,7.8 20,10 C 20,16 12,21 12,21 Z" />
                            </Border>

                            <Border Style="{StaticResource IconCircleStyle}"
                                    BackgroundColor="#e07038">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnUploadTapped" />
                                </Border.GestureRecognizers>
                                <Path Stroke="White" StrokeThickness="1.7" Fill="Transparent"
                                      Aspect="Uniform" HeightRequest="18" WidthRequest="18"
                                      HorizontalOptions="Center" VerticalOptions="Center"
                                      Data="M 12,4 L 12,16 M 6,10 L 12,4 L 18,10 M 4,20 L 20,20" />
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Search bar -->
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="Transparent"
                            BackgroundColor="White"
                            Padding="0"
                            HeightRequest="52">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.12" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="14,0" ColumnSpacing="8">
                            <Path Grid.Column="0"
                                  Stroke="#98a8a0" StrokeThickness="1.7"
                                  Fill="Transparent" Aspect="Uniform"
                                  HeightRequest="16" WidthRequest="16"
                                  VerticalOptions="Center"
                                  Data="M 10,4 C 6.7,4 4,6.7 4,10 C 4,13.3 6.7,16 10,16 C 13.3,16 16,13.3 16,10 C 16,6.7 13.3,4 10,4 Z M 14.5,14.5 L 20,20" />
                            <Entry x:Name="SearchEntry"
                                   Grid.Column="1"
                                   Placeholder="Otsi pealkirja või žanri..."
                                   Text="{Binding SearchText}"
                                   FontSize="14"
                                   TextColor="#1f2e28"
                                   PlaceholderColor="#a8b5ad"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="2"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    BackgroundColor="#2d6e68"
                                    Padding="22,0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SearchCommand}"
                                                          CommandParameter="{Binding SearchText}" />
                                </Border.GestureRecognizers>
                                <Label x:Name="SearchBtnLabel"
                                       Text="Otsi"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Welcome card -->
            <Border Margin="24,12,24,0"
                    StrokeShape="RoundRectangle 14"
                    Stroke="Transparent"
                    BackgroundColor="#e8f0ed"
                    Padding="20,16">
                <VerticalStackLayout Spacing="2">
                    <Label x:Name="WelcomeLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1f2e28" />
                    <Label x:Name="WelcomeSubLabel"
                           Text="Siin on sinu raamatud"
                           FontSize="13"
                           TextColor="#3a5c52" />
                </VerticalStackLayout>
            </Border>

            <!-- Filters -->
            <VerticalStackLayout Spacing="12" Margin="0,28,0,0">

                <Label x:Name="FiltersLabel"
                       Text="FILTRID"
                       FontSize="11"
                       TextColor="#98a8a0"
                       CharacterSpacing="3"
                       Margin="32,0,0,0" />

                <!-- Genre chips — bind to Nimetus property of Genre object -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Never"
                            Padding="28,0,28,8">
                    <HorizontalStackLayout x:Name="GenresLayout"
                                           Spacing="8"
                                           BindableLayout.ItemsSource="{Binding Genres}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 18"
                                        StrokeThickness="1"
                                        Padding="16,7"
                                        HeightRequest="34"
                                        BackgroundColor="White"
                                        Stroke="#d5dfd8">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnGenreChipTapped" />
                                    </Border.GestureRecognizers>
                                    <!-- FIX: bind to Nimetus, not the whole object -->
                                    <Label Text="{Binding Nimetus}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#3a5c52"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- File type chips -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Never"
                            Padding="28,0,28,8">
                    <HorizontalStackLayout x:Name="FileTypeLayout" Spacing="8">

                        <Border x:Name="FileTypeAll"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="1"
                                Padding="16,7"
                                HeightRequest="34"
                                BackgroundColor="#2d6e68"
                                Stroke="#2d6e68">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFileTypeChipTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="FileTypeAllLabel"
                                   Text="Kõik failid"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                        </Border>

                        <Border x:Name="FileTypeEpub"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="1"
                                Padding="16,7"
                                HeightRequest="34"
                                BackgroundColor="White"
                                Stroke="#d5dfd8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFileTypeChipTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="EPUB"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#3a5c52"
                                   VerticalOptions="Center" />
                        </Border>

                        <Border x:Name="FileTypePdf"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="1"
                                Padding="16,7"
                                HeightRequest="34"
                                BackgroundColor="White"
                                Stroke="#d5dfd8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFileTypeChipTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="PDF"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#3a5c52"
                                   VerticalOptions="Center" />
                        </Border>

                        <Border x:Name="FileTypeTxt"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="1"
                                Padding="16,7"
                                HeightRequest="34"
                                BackgroundColor="White"
                                Stroke="#d5dfd8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFileTypeChipTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="TXT"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#3a5c52"
                                   VerticalOptions="Center" />
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- Books section -->
            <VerticalStackLayout Spacing="16" Margin="32,28,32,40">

                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="BooksSectionTitle"
                               Text="Raamatud"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#1f2e28" />
                        <Label x:Name="BooksSectionSubtitle"
                               Text="Vali endale meelepärane"
                               FontSize="12"
                               TextColor="#98a8a0" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1"
                           Text="Kõik →"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#2d6e68"
                           VerticalOptions="Center" />
                </Grid>

                <CollectionView x:Name="BooksCollectionView"
                                ItemsSource="{Binding Books}"
                                SelectionMode="Single"
                                SelectionChanged="OnBookSelected">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout x:Name="BooksGridLayout"
                                         Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="14"
                                         VerticalItemSpacing="22" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="10" Padding="2">
                                <Grid>
                                    <Border StrokeShape="RoundRectangle 10"
                                            Stroke="Transparent"
                                            Padding="0"
                                            HeightRequest="260"
                                            HorizontalOptions="Fill">
                                        <Border.Shadow>
                                            <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.18" />
                                        </Border.Shadow>
                                        <Image Source="{Binding PiltOrPlaceholder}" Aspect="AspectFill" />
                                    </Border>

                                    <Border StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            BackgroundColor="{Binding StatusColor}"
                                            Padding="8,4"
                                            HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                            Margin="8,8,0,0"
                                            IsVisible="{Binding StatusLabel, Converter={StaticResource NullToBoolConverter}}">
                                        <Label Text="{Binding StatusLabel}"
                                               FontSize="10"
                                               FontAttributes="Bold"
                                               TextColor="White" />
                                    </Border>
                                </Grid>

                                <VerticalStackLayout Spacing="3" Padding="2,0">
                                    <Label Text="{Binding Pealkiri}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1f2e28"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                    <Label Text="{Binding Zanr_Nimi}"
                                           FontSize="11"
                                           TextColor="#98a8a0" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
