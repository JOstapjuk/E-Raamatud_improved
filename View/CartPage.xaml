<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.CartPage"
             x:Name="CartPageRef"
             BackgroundColor="#FAF8F3"
             SizeChanged="OnPageSizeChanged"
             Shell.NavBarIsVisible="False"
             Title="Ostukorv">

    <Grid RowDefinitions="Auto, *">

        <!-- ============== ШАПКА ============== -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,50,24,28"
                  ColumnDefinitions="Auto, *, Auto">

                <!-- Назад -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#1f4f4a"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path Stroke="White" StrokeThickness="2"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="16" WidthRequest="16"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 14,6 L 8,12 L 14,18" />
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Label Text="Ostukorv"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label x:Name="ItemCountLabel"
                           Text="0 raamatut"
                           FontSize="12"
                           TextColor="#c8e0dc"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Заглушка справа для симметрии -->
                <BoxView Grid.Column="2"
                         WidthRequest="40"
                         HeightRequest="40"
                         Color="Transparent" />
            </Grid>
        </Border>

        <!-- ============== КОНТЕНТ ============== -->
        <Grid Grid.Row="1" x:Name="ContentRoot">

            <!-- ===== ПУСТАЯ КОРЗИНА ===== -->
            <VerticalStackLayout x:Name="EmptyCartView"
                                 IsVisible="False"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="40">

                <Border StrokeShape="RoundRectangle 50"
                        Stroke="Transparent"
                        BackgroundColor="#fff5e8"
                        WidthRequest="120"
                        HeightRequest="120"
                        Padding="0">
                    <Path Stroke="#d97a4a" StrokeThickness="2.5"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="56" WidthRequest="56"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 3,3 L 5,3 L 6,6 M 6,6 L 8,14 L 18,14 L 20,7 L 7,7 M 9,19 C 9,19.6 8.6,20 8,20 C 7.4,20 7,19.6 7,19 C 7,18.4 7.4,18 8,18 C 8.6,18 9,18.4 9,19 Z M 18,19 C 18,19.6 17.6,20 17,20 C 16.4,20 16,19.6 16,19 C 16,18.4 16.4,18 17,18 C 17.6,18 18,18.4 18,19 Z" />
                </Border>

                <Label Text="Sinu ostukorv on tühi"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1f2e28"
                       HorizontalOptions="Center" />

                <Label Text="Lisa siia raamatuid, mida soovid osta"
                       FontSize="14"
                       TextColor="#5f5e5a"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" />

                <Button Text="Sirvi raamatuid"
                        Clicked="OnBackTapped"
                        BackgroundColor="#2d6e68"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="10"
                        HeightRequest="48"
                        WidthRequest="200"
                        Margin="0,12,0,0" />
            </VerticalStackLayout>

            <!-- ===== ОСНОВНОЙ КОНТЕНТ С ТОВАРАМИ ===== -->
            <Grid x:Name="MainContent"
                  Padding="32,28,32,32"
                  ColumnSpacing="24"
                  RowSpacing="24">

                <!-- ===== ЛЕВАЯ КОЛОНКА: список товаров ===== -->
                <VerticalStackLayout x:Name="ItemsPanel" Spacing="14">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               Text="Sinu raamatud"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#1f2e28" />
                        <Label Grid.Column="1"
                               x:Name="ItemCountInline"
                               Text=""
                               FontSize="13"
                               TextColor="#98a8a0"
                               VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding CartItems}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 12"
                                        Stroke="#e5ebe7"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.05" />
                                    </Border.Shadow>

                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">

                                        <!-- Обложка -->
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 8"
                                                Stroke="Transparent"
                                                Padding="0"
                                                WidthRequest="80"
                                                HeightRequest="120">
                                            <Border.Shadow>
                                                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.15" />
                                            </Border.Shadow>
                                            <Image Source="{Binding BookImage}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <!-- Название и цена -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="6"
                                                             VerticalOptions="Center">

                                            <Border StrokeShape="RoundRectangle 6"
                                                    Stroke="Transparent"
                                                    BackgroundColor="#e8f0ed"
                                                    Padding="8,3"
                                                    HorizontalOptions="Start">
                                                <Label Text="E-RAAMAT"
                                                       FontSize="9"
                                                       FontAttributes="Bold"
                                                       TextColor="#0f6e56"
                                                       CharacterSpacing="1.5" />
                                            </Border>

                                            <Label Text="{Binding BookTitle}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="#1f2e28"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />

                                            <Label Text="{Binding BookPrice, StringFormat='€ {0:F2}'}"
                                                   FontSize="17"
                                                   FontAttributes="Bold"
                                                   TextColor="#2d6e68"
                                                   Margin="0,4,0,0" />
                                        </VerticalStackLayout>

                                        <!-- Кнопка удаления -->
                                        <Border Grid.Column="2"
                                                StrokeShape="RoundRectangle 18"
                                                Stroke="Transparent"
                                                BackgroundColor="#fdecec"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                Padding="0"
                                                VerticalOptions="Start">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding BindingContext.RemoveCommand, Source={x:Reference Name=CartPageRef}}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Path Stroke="#d63030" StrokeThickness="2"
                                                  Fill="Transparent" Aspect="Uniform"
                                                  HeightRequest="14" WidthRequest="14"
                                                  HorizontalOptions="Center" VerticalOptions="Center"
                                                  Data="M 5,5 L 15,15 M 15,5 L 5,15" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ===== ПРАВАЯ КОЛОНКА: summary ===== -->
                <Border x:Name="SummaryPanel"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#e5ebe7"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="22"
                        VerticalOptions="Start">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.06" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="14">

                        <Label Text="Tellimuse kokkuvõte"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1f2e28" />

                        <BoxView HeightRequest="1"
                                 Color="#e5ebe7"
                                 HorizontalOptions="Fill" />

                        <!-- Subtotal -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="Vahesumma"
                                   FontSize="13"
                                   TextColor="#5f5e5a"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='€ {0:F2}'}"
                                   FontSize="13"
                                   TextColor="#1f2e28"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Доставка -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="Kohaletoimetamine"
                                   FontSize="13"
                                   TextColor="#5f5e5a"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="Tasuta"
                                   FontSize="13"
                                   TextColor="#0f6e56"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1"
                                 Color="#e5ebe7"
                                 HorizontalOptions="Fill" />

                        <!-- Итого -->
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0"
                                   Text="Kokku"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#1f2e28"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding TotalPrice, StringFormat='€ {0:F2}'}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#2d6e68"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Button Text="Vormista ost"
                                Command="{Binding BuyCommand}"
                                BackgroundColor="#2d6e68"
                                TextColor="White"
                                FontAttributes="Bold"
                                FontSize="15"
                                CornerRadius="10"
                                HeightRequest="52"
                                Margin="0,8,0,0" />

                        <!-- Доверие-блок -->
                        <VerticalStackLayout Spacing="10" Margin="0,8,0,0">

                            <HorizontalStackLayout Spacing="10">
                                <Path Stroke="#0f6e56" StrokeThickness="1.7"
                                      Fill="Transparent" Aspect="Uniform"
                                      HeightRequest="16" WidthRequest="16"
                                      VerticalOptions="Center"
                                      Data="M 12,3 L 4,6 L 4,12 C 4,16 7,20 12,21 C 17,20 20,16 20,12 L 20,6 Z M 9,12 L 11,14 L 15,10" />
                                <Label Text="Turvaline ost (SSL)"
                                       FontSize="12"
                                       TextColor="#5f5e5a"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Path Stroke="#534ab7" StrokeThickness="1.7"
                                      Fill="Transparent" Aspect="Uniform"
                                      HeightRequest="16" WidthRequest="16"
                                      VerticalOptions="Center"
                                      Data="M 4,12 C 4,7.6 7.6,4 12,4 C 14.5,4 16.7,5.2 18,7 M 20,4 L 20,8 L 16,8 M 20,12 C 20,16.4 16.4,20 12,20 C 9.5,20 7.3,18.8 6,17 M 4,20 L 4,16 L 8,16" />
                                <Label Text="14 päeva tagastusõigus"
                                       FontSize="12"
                                       TextColor="#5f5e5a"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Path Stroke="#993c1d" StrokeThickness="1.7"
                                      Fill="Transparent" Aspect="Uniform"
                                      HeightRequest="16" WidthRequest="16"
                                      VerticalOptions="Center"
                                      Data="M 3,7 L 14,7 L 14,17 L 3,17 Z M 14,10 L 19,10 L 21,13 L 21,17 L 14,17" />
                                <Label Text="Kiire kohaletoimetamine"
                                       FontSize="12"
                                       TextColor="#5f5e5a"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>