<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="E_Raamatud.View.AccountSettingsPage"
             x:Name="AccountSettingsPageRef"
             BackgroundColor="#FAF8F3"
             SizeChanged="OnPageSizeChanged"
             Shell.NavBarIsVisible="False"
             Title="Konto seaded">

    <ContentPage.Resources>
        <Style x:Key="FieldEntryStyle" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="#1f2e28" />
            <Setter Property="PlaceholderColor" Value="#8a9a92" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HeightRequest" Value="46" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <!-- ============== HEADER ============== -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,50,24,28"
                  ColumnDefinitions="Auto, *, Auto">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#1f4f4a"
                        WidthRequest="40"
                        HeightRequest="40"
                        Padding="0"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path Stroke="White" StrokeThickness="2"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="16" WidthRequest="16"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 14,6 L 8,12 L 14,18" />
                </Border>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                    <Label Text="Konto seaded"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Halda oma konto andmeid ja parooli"
                           FontSize="12"
                           TextColor="#c8e0dc"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Label Grid.Column="2"
                       WidthRequest="40"
                       HeightRequest="40" />
            </Grid>
        </Border>

        <!-- ============== CONTENT ============== -->
        <ScrollView Grid.Row="1">
            <Grid x:Name="ContentRoot"
                  Padding="32,28,32,32"
                  ColumnSpacing="24"
                  RowSpacing="24">

                <!-- ===== LEFT COLUMN: profile ===== -->
                <Border x:Name="ProfileCard"
                        StrokeShape="RoundRectangle 14"
                        Stroke="#e5ebe7"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="24"
                        VerticalOptions="Start">
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.06" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                        <!-- Avatar: stacked initials circle + photo + camera button -->
                        <Grid WidthRequest="100" HeightRequest="100" HorizontalOptions="Center">

                            <!-- Initials fallback -->
                            <Border x:Name="AvatarBorder"
                                    StrokeShape="RoundRectangle 50"
                                    Stroke="Transparent"
                                    BackgroundColor="#2d6e68"
                                    WidthRequest="100"
                                    HeightRequest="100"
                                    Padding="0">
                                <Label x:Name="AvatarInitial"
                                       Text="?"
                                       FontSize="38"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <!-- Profile picture (visible when set) -->
                            <Border x:Name="AvatarImageBorder"
                                StrokeShape="RoundRectangle 50"
                                Stroke="Transparent"
                                WidthRequest="100"
                                HeightRequest="100"
                                IsVisible="False"
                                Padding="0">
                                <Image x:Name="ProfileImage"
                                       Aspect="AspectFill"
                                       WidthRequest="100"
                                       HeightRequest="100" />
                            </Border>

                            <!-- Camera button overlay -->
                            <Border StrokeShape="RoundRectangle 16"
                                    BackgroundColor="#2d6e68"
                                    Stroke="White"
                                    StrokeThickness="2"
                                    WidthRequest="32"
                                    HeightRequest="32"
                                    HorizontalOptions="End"
                                    VerticalOptions="End">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnChangeAvatarTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="📷"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Label x:Name="ProfileName"
                               Text="{Binding Username}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1f2e28"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />

                        <Border StrokeShape="RoundRectangle 6"
                                Stroke="Transparent"
                                BackgroundColor="#e8f0ed"
                                Padding="10,4"
                                HorizontalOptions="Center">
                            <Label Text="AKTIIVNE KASUTAJA"
                                   FontSize="9"
                                   FontAttributes="Bold"
                                   TextColor="#0f6e56"
                                   CharacterSpacing="1.5" />
                        </Border>

                        <BoxView HeightRequest="1"
                                 Color="#e5ebe7"
                                 HorizontalOptions="Fill"
                                 Margin="0,8,0,4" />

                        <!-- Security hints -->
                        <VerticalStackLayout Spacing="14" HorizontalOptions="Start">

                            <HorizontalStackLayout Spacing="10">
                                <Border StrokeShape="RoundRectangle 16"
                                        Stroke="Transparent"
                                        BackgroundColor="#e8f0ed"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        Padding="0">
                                    <Path Stroke="#0f6e56" StrokeThickness="1.7"
                                          Fill="Transparent" Aspect="Uniform"
                                          HeightRequest="14" WidthRequest="14"
                                          HorizontalOptions="Center" VerticalOptions="Center"
                                          Data="M 12,3 L 4,6 L 4,12 C 4,16 7,20 12,21 C 17,20 20,16 20,12 L 20,6 Z M 9,12 L 11,14 L 15,10" />
                                </Border>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Konto on kaitstud"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#1f2e28" />
                                    <Label Text="SSL krüpteering aktiveeritud"
                                           FontSize="10"
                                           TextColor="#5f5e5a" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Border StrokeShape="RoundRectangle 16"
                                        Stroke="Transparent"
                                        BackgroundColor="#fff5e8"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        Padding="0">
                                    <Path Stroke="#993c1d" StrokeThickness="1.7"
                                          Fill="Transparent" Aspect="Uniform"
                                          HeightRequest="14" WidthRequest="14"
                                          HorizontalOptions="Center" VerticalOptions="Center"
                                          Data="M 12,2 L 4,7 L 4,11 C 4,16 8,21 12,22 C 16,21 20,16 20,11 L 20,7 Z" />
                                </Border>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Kasuta tugevat parooli"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#1f2e28" />
                                    <Label Text="Vähemalt 8 tähemärki"
                                           FontSize="10"
                                           TextColor="#5f5e5a" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Border StrokeShape="RoundRectangle 16"
                                        Stroke="Transparent"
                                        BackgroundColor="#f0eaf7"
                                        WidthRequest="32"
                                        HeightRequest="32"
                                        Padding="0">
                                    <Path Stroke="#534ab7" StrokeThickness="1.7"
                                          Fill="Transparent" Aspect="Uniform"
                                          HeightRequest="14" WidthRequest="14"
                                          HorizontalOptions="Center" VerticalOptions="Center"
                                          Data="M 12,8 L 12,12 L 14,14 M 4,12 C 4,7.6 7.6,4 12,4 C 16.4,4 20,7.6 20,12 C 20,16.4 16.4,20 12,20 C 7.6,20 4,16.4 4,12 Z" />
                                </Border>
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Vaheta parooli regulaarselt"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#1f2e28" />
                                    <Label Text="Iga 3-6 kuu tagant"
                                           FontSize="10"
                                           TextColor="#5f5e5a" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ===== RIGHT COLUMN: form ===== -->
                <VerticalStackLayout x:Name="FormPanel" Spacing="20">

                    <!-- Block 1: Profile -->
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="#e5ebe7"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="24">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.06" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="2">
                                <Label Text="Profiili andmed"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#1f2e28" />
                                <Label Text="Muuda oma kasutajanime"
                                       FontSize="12"
                                       TextColor="#98a8a0" />
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e5ebe7" HorizontalOptions="Fill" />

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Kasutajanimi"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#3a5c52"
                                       CharacterSpacing="0.5" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="#d5dfd8"
                                        StrokeThickness="1"
                                        BackgroundColor="#fafbfa"
                                        Padding="14,2">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Path Grid.Column="0"
                                              Stroke="#8a9a92" StrokeThickness="1.7"
                                              Fill="Transparent" Aspect="Uniform"
                                              HeightRequest="16" WidthRequest="16"
                                              Margin="0,0,10,0"
                                              VerticalOptions="Center"
                                              Data="M 12,12 C 14.2,12 16,10.2 16,8 C 16,5.8 14.2,4 12,4 C 9.8,4 8,5.8 8,8 C 8,10.2 9.8,12 12,12 Z M 12,14 C 9.3,14 4,15.3 4,18 L 4,20 L 20,20 L 20,18 C 20,15.3 14.7,14 12,14 Z" />
                                        <Entry Grid.Column="1"
                                               Style="{StaticResource FieldEntryStyle}"
                                               Text="{Binding Username}"
                                               Placeholder="Kasutajanimi" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Block 2: Password -->
                    <Border StrokeShape="RoundRectangle 14"
                            Stroke="#e5ebe7"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="24">
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.06" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="2">
                                <Label Text="Vaheta parooli"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#1f2e28" />
                                <Label Text="Sisesta praegune ja uus parool"
                                       FontSize="12"
                                       TextColor="#98a8a0" />
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#e5ebe7" HorizontalOptions="Fill" />

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Praegune parool"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#3a5c52"
                                       CharacterSpacing="0.5" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="#d5dfd8"
                                        StrokeThickness="1"
                                        BackgroundColor="#fafbfa"
                                        Padding="14,2">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Path Grid.Column="0"
                                              Stroke="#8a9a92" StrokeThickness="1.7"
                                              Fill="Transparent" Aspect="Uniform"
                                              HeightRequest="16" WidthRequest="16"
                                              Margin="0,0,10,0"
                                              VerticalOptions="Center"
                                              Data="M 6,10 L 6,7 C 6,4.2 8.2,2 11,2 L 13,2 C 15.8,2 18,4.2 18,7 L 18,10 M 4,10 L 20,10 L 20,21 L 4,21 Z" />
                                        <Entry Grid.Column="1"
                                               Style="{StaticResource FieldEntryStyle}"
                                               Text="{Binding CurrentPassword}"
                                               IsPassword="True"
                                               Placeholder="Sisesta praegune parool" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Uus parool"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#3a5c52"
                                       CharacterSpacing="0.5" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="#d5dfd8"
                                        StrokeThickness="1"
                                        BackgroundColor="#fafbfa"
                                        Padding="14,2">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Path Grid.Column="0"
                                              Stroke="#8a9a92" StrokeThickness="1.7"
                                              Fill="Transparent" Aspect="Uniform"
                                              HeightRequest="16" WidthRequest="16"
                                              Margin="0,0,10,0"
                                              VerticalOptions="Center"
                                              Data="M 6,10 L 6,7 C 6,4.2 8.2,2 11,2 L 13,2 C 15.8,2 18,4.2 18,7 L 18,10 M 4,10 L 20,10 L 20,21 L 4,21 Z" />
                                        <Entry Grid.Column="1"
                                               Style="{StaticResource FieldEntryStyle}"
                                               Text="{Binding NewPassword}"
                                               IsPassword="True"
                                               Placeholder="Vähemalt 8 tähemärki" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Kinnita uus parool"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#3a5c52"
                                       CharacterSpacing="0.5" />
                                <Border StrokeShape="RoundRectangle 10"
                                        Stroke="#d5dfd8"
                                        StrokeThickness="1"
                                        BackgroundColor="#fafbfa"
                                        Padding="14,2">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Path Grid.Column="0"
                                              Stroke="#8a9a92" StrokeThickness="1.7"
                                              Fill="Transparent" Aspect="Uniform"
                                              HeightRequest="16" WidthRequest="16"
                                              Margin="0,0,10,0"
                                              VerticalOptions="Center"
                                              Data="M 4,12 L 9,17 L 20,6" />
                                        <Entry Grid.Column="1"
                                               Style="{StaticResource FieldEntryStyle}"
                                               Text="{Binding ConfirmPassword}"
                                               IsPassword="True"
                                               Placeholder="Sisesta uus parool uuesti" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Save button -->
                    <Button Text="Salvesta muudatused"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="#2d6e68"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="15"
                            CornerRadius="10"
                            HeightRequest="54" />

                </VerticalStackLayout>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
