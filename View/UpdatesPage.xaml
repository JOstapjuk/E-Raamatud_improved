<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:E_Raamatud.Resources.Localization"
             x:Class="E_Raamatud.View.UpdatesPage"
             BackgroundColor="#FAF8F3"
             Shell.NavBarIsVisible="False"
             Title="{x:Static loc:AppResources.UpdatesTitle}">

    <Grid RowDefinitions="Auto, *">

        <!-- HEADER -->
        <Border Grid.Row="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Stroke="Transparent"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2d6e68" Offset="0.0" />
                    <GradientStop Color="#3a7d82" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="24,50,24,28" ColumnDefinitions="Auto, *, Auto">

                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#1f4f4a"
                        WidthRequest="40" HeightRequest="40"
                        Padding="0" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path Stroke="White" StrokeThickness="2"
                          Fill="Transparent" Aspect="Uniform"
                          HeightRequest="16" WidthRequest="16"
                          HorizontalOptions="Center" VerticalOptions="Center"
                          Data="M 14,6 L 8,12 L 14,18" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2"
                                     VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="{x:Static loc:AppResources.UpdatesTitle}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Label Text="{x:Static loc:AppResources.UpdatesSubtitle}"
                           FontSize="12" TextColor="#c8e0dc"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Label Grid.Column="2" WidthRequest="40" HeightRequest="40" />
            </Grid>
        </Border>

