                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="VIIMANE VERSIOON"
                                   FontSize="10" TextColor="#a8d4cf"
                                   CharacterSpacing="2" FontAttributes="Bold" />
                            <Label Text="v1.6.0"
